# Data files
# Sensor CSVs and processed datasets should not be tracked
data/raw/*.csv
data/processed/
!data/raw/.gitkeep
!data/processed/.gitkeep

# Analysis Output
# Generated JSON reports and PNG plots from the analysis pipeline
data/reports/*
reports/
*.json
*.png
*.pdf

# Python artifacts
# Compiled files and cache generated by NumPy, Pandas, and SciPy[cite: 8]
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Environments
# Virtual environments used for dependency management
.venv/
venv/
env/
.env

# Notebooks
# Checkpoints from exploratory analysis
.ipynb_checkpoints/

# IDE and OS
.vscode/
.idea/
.DS_Store
Thumbs.db
